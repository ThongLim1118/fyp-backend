{
    "dataformat_ohlcv": "feather",
    "trading_mode": "spot",
    "dry_run": true,
    "strategy": "RsiStrategy",
    "strategy_path": "user_data/strategies",
    "stake_currency": "USDT",
    "stake_amount": 100,
    "exchange": {
        "name": "binance",
        "sandbox": false,
        "ccxt_config": {
            "enableRateLimit": true,
            "timeout": 30000,
            "options": {
                "defaultType": "spot",
                "recvWindow": 10000
            }
        },
        "ccxt_async_config": {
            "enableRateLimit": true,
            "timeout": 30000,
            "options": {
                "defaultType": "spot"
            }
        }
    },
    "markets_refresh_interval": 900,
    "timerange": null,
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "pair_whitelist": [
        "BTC/USDT",
        "ETH/USDT",
        "XRP/USDT"
    ],
    "datadir": "user_data/data",
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "stoploss": "market",
        "stoploss_on_exchange": true
    },
    "entry_pricing": {
        "price_side": "ask",
        "use_order_book": false,
        "order_book_top": 1,
        "check_depth_of_market": {
            "enabled": false,
            "interval": 60,
            "threshold": 0.1
        }
    },
    "exit_strategy": {},
    "exit_pricing": {
        "price_side": "ask",
        "use_order_book": false,
        "order_book_top": 1,
        "check_depth_of_market": {
            "enabled": false,
            "interval": 60,
            "threshold": 0.1
        }
    },
    "db_url": "postgresql://postgres:afubo1234@db.zgvzascfyfvtpmdetrwg.supabase.co:5432/postgres"
}